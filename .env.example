# Copy to .env and fill in. NEVER commit .env.

# Home Assistant
HA_URL=http://homeassistant.iot:8123
# Long-lived access token (HA profile -> Security -> Long-lived access tokens)
HA_TOKEN=

# Ollama endpoints (not used until Phase 3; plumbed now)
OLLAMA_PRIMARY=http://192.168.85.61:11434
OLLAMA_FALLBACK=http://192.168.6.164:11434

# Database (compose-internal hostname `db`; use 127.0.0.1:5432 from the host)
DB_URL=postgresql+psycopg://pae:pae@db:5432/pae

# Redis (compose-internal hostname `redis`; use 127.0.0.1:6379 from the host)
REDIS_URL=redis://redis:6379/0

# Logging: json (Loki) or console (local dev)
LOG_LEVEL=INFO
LOG_FORMAT=json

# Global read-only mode. Leave true — Phase 0 has no write paths at all.
PAE_READ_ONLY=true

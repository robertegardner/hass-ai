{
  "__inputs": [
    {
      "name": "DS_PAE_POSTGRES",
      "label": "PAE Postgres",
      "description": "PostgreSQL datasource pointing at the PAE TimescaleDB",
      "type": "datasource",
      "pluginId": "postgres",
      "pluginName": "PostgreSQL"
    }
  ],
  "title": "PAE #1 — Ingestion",
  "uid": "pae-ingestion",
  "tags": ["pae"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Event volume by domain",
      "type": "timeseries",
      "datasource": { "type": "postgres", "uid": "${DS_PAE_POSTGRES}" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT $__timeGroup(time, '15m') AS time, domain AS metric, count(*) AS events FROM events WHERE $__timeFilter(time) GROUP BY 1, 2 ORDER BY 1"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "bars", "stacking": { "mode": "normal" }, "fillOpacity": 60 } },
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "Manual vs automation",
      "type": "timeseries",
      "datasource": { "type": "postgres", "uid": "${DS_PAE_POSTGRES}" },
      "gridPos": { "h": 9, "w": 8, "x": 12, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT $__timeGroup(time, '30m') AS time, triggered_by AS metric, count(*) AS events FROM events WHERE $__timeFilter(time) GROUP BY 1, 2 ORDER BY 1"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "bars", "stacking": { "mode": "percent" }, "fillOpacity": 60 } },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "Manual share (window)",
      "type": "stat",
      "datasource": { "type": "postgres", "uid": "${DS_PAE_POSTGRES}" },
      "gridPos": { "h": 9, "w": 4, "x": 20, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT round(100.0 * count(*) FILTER (WHERE triggered_by = 'manual') / greatest(count(*), 1), 1) AS manual_pct FROM events WHERE $__timeFilter(time)"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] }
    },
    {
      "id": 4,
      "title": "Presence timeline (person entities)",
      "type": "state-timeline",
      "datasource": { "type": "postgres", "uid": "${DS_PAE_POSTGRES}" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 9 },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT time, person AS metric, room AS value FROM presence_snapshots WHERE source = 'person' AND $__timeFilter(time) ORDER BY time"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 70 } },
        "overrides": []
      }
    },
    {
      "id": 5,
      "title": "Room-level person detections (UniFi)",
      "type": "timeseries",
      "datasource": { "type": "postgres", "uid": "${DS_PAE_POSTGRES}" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 9 },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT $__timeGroup(time, '30m') AS time, room AS metric, count(*) AS detections FROM presence_snapshots WHERE source = 'unifi' AND $__timeFilter(time) GROUP BY 1, 2 ORDER BY 1"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "bars", "stacking": { "mode": "normal" }, "fillOpacity": 60 } },
        "overrides": []
      }
    },
    {
      "id": 6,
      "title": "Context frames: persons home + outside temp",
      "type": "timeseries",
      "datasource": { "type": "postgres", "uid": "${DS_PAE_POSTGRES}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 18 },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT time, (SELECT count(*) FROM jsonb_each_text(persons_home) AS p(k, v) WHERE v NOT IN ('not_home', 'unknown')) AS persons_home, outside_temp FROM context_frames WHERE $__timeFilter(time) ORDER BY time"
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] }
    }
  ]
}
